# Required for the digital-twin chat route (src/app/api/chat/route.ts) to work locally.
OPENROUTER_API_KEY=

# Optional. When set, the contact form posts to this endpoint. When unset,
# the UI falls back to showing direct contact links instead of a form.
NEXT_PUBLIC_FORM_ENDPOINT=

# Optional. Comma-separated list of extra origins allowed to reach the dev
# server (e.g. a phone's LAN IP), since `npm run dev` binds 0.0.0.0.
ALLOWED_DEV_ORIGIN=
